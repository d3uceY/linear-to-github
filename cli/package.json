{
  "name": "linear-to-github",
  "version": "1.0.0",
  "description": "turn linear issues into github issues",
  "main": "dist/index.js",
  "bin": {
    "linear-to-github": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bazylhorsey/linear-to-github.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bazylhorsey/linear-to-github/issues"
  },
  "homepage": "https://github.com/bazylhorsey/linear-to-github#readme",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^@octokit/(.*)$": "<rootDir>/src/__mocks__/@octokit/$1.js"
    }
  },
  "dependencies": {
    "@linear/sdk": "^76.0.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
