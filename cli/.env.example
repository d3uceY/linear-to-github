# Linear API key (from Linear settings > API > Personal API keys)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository owner (username or organization)
GITHUB_OWNER=your-github-username

# GitHub repository name to transfer issues into
GITHUB_REPO=your-repo-name

# Optional: Linear team ID to filter issues (leave blank to transfer all issues)
LINEAR_TEAM_ID=
